<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" path="/index.html" responseMode="ExecuteURL" />
    </httpErrors>

    <!-- Prevent caching index.html so browser always gets latest chunk references -->
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>

    <!-- Cache JS/CSS assets forever (they have content hashes in filenames) -->
    <rewrite>
      <outboundRules>
        <rule name="Cache hashed assets" preCondition="IsHashedAsset">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="public, max-age=31536000, immutable" />
        </rule>
        <preConditions>
          <preCondition name="IsHashedAsset">
            <add input="{REQUEST_URI}" pattern="/assets/.*-[a-zA-Z0-9]{8}\.(js|css)$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>
  </system.webServer>
</configuration>
